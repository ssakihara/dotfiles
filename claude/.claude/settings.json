{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NEW_INIT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm ls:*)",
      "Bash(npx vitest run:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(obsidian append:*)",
      "Bash(obsidian create:*)",
      "Bash(obsidian search:*)",
      "Bash(obsidian read:*)",
      "Bash(obsidian help)",
      "Bash(obsidian --help)",
      "Bash(agent-browser snapshot:*)",
      "Bash(agent-browser eval:*)",
      "Bash(agent-browser screenshot:*)",
      "Bash(agent-browser find:*)",
      "Bash(agent-browser reload:*)",
      "Bash(agent-browser wait:*)",
      "Bash(agent-browser get:*)",
      "Bash(agent-browser console:*)",
      "Bash(agent-browser errors:*)",
      "Bash(agent-browser close:*)",
      "Bash(agent-browser open:*)",
      "Edit(**/*.{vue,ts})",
      "Read(**/*.{vue,ts})",
      "Read(~/.agent-browser/tmp/screenshots/screenshot-*.png)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(**/*.env)",
      "Read(**/.env.*)",
      "Bash(curl:*)",
      "Edit(/etc/**)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"タスクが完了しました\" with title \"Claude Code\" subtitle \"処理終了\" sound name \"Hero\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.mjs"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "common-skills@aem-ssakihara": true
  },
  "extraKnownMarketplaces": {
    "aem-ssakihara": {
      "source": {
        "source": "directory",
        "path": "/Users/s.sakihara/workspaces/github.com/axelentermedia/ssakihara/claude"
      }
    }
  },
  "language": "japanese",
  "plansDirectory": "./plans",
  "voiceEnabled": true,
  "autoMemoryEnabled": false
}
