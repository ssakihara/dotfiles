{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NEW_INIT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(npm run:*)",
      "Bash(npm ls:*)",
      "Bash(pnpm run:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(obsidian append:*)",
      "Bash(obsidian create:*)",
      "Bash(obsidian search:*)",
      "Bash(obsidian read:*)",
      "Bash(obsidian help)",
      "Bash(obsidian --help)",
      "Bash(agent-browser:*)",
      "Edit(**/*.{vue,ts})",
      "Read(**/*.{vue,ts})",
      "Read(~/.agent-browser/tmp/screenshots/screenshot-*.png)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(**/*.env)",
      "Read(**/.env.*)",
      "Bash(curl:*)",
      "Bash(pnpm i)",
      "Bash(pnpm install)",
      "Bash(grep:*)",
      "Edit(/etc/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -subtitle '確認待ち' -message 'Claude Codeが許可を求めています' -sound Glass -contentImage ~/.claude/assets/claudecode-color.png"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -subtitle '処理終了' -message 'タスクが完了しました' -sound Hero -contentImage ~/.claude/assets/claudecode-color.png"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.mjs"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "language": "japanese",
  "effortLevel": "xhigh",
  "plansDirectory": "./plans",
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "model": "claude-opus-4-6"
}
