{
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm ls:*)",
      "Bash(npm install:*)",
      "Bash(agent-browser:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Edit(**/*.{vue,ts})",
      "Read(**/*.{vue,ts})"
    ],
    "deny": ["Read(./.env)", "Read(**/*.env)", "Bash(curl:*)", "Edit(/etc/**)"]
  },
  "plansDirectory": "./plans"
}
